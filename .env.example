NODE_ENV=development
HOST=0.0.0.0
PORT=3000
APP_ORIGIN=http://localhost:3001
API_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegis
REDIS_URL=redis://localhost:6379
SESSION_COOKIE_NAME=aegis_session
CSRF_COOKIE_NAME=aegis_csrf
SESSION_TTL_MINUTES=120
SESSION_IDLE_TIMEOUT_MINUTES=30
SECURE_COOKIES=false
STORAGE_DRIVER=memory
SESSION_DRIVER=memory
ALLOW_NATIVE_FALLBACK=true
ENABLE_DEMO_SEED=true
TRUST_PROXY=true
RISK_BLOCK_THRESHOLD=80
RISK_CHALLENGE_THRESHOLD=55
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_IP_MAX=100
RATE_LIMIT_ACCOUNT_MAX=20
MAX_JSON_BODY_BYTES=16384
MAX_UPLOAD_BYTES=5000000
PASSWORD_SCRYPT_COST=16384
PASSWORD_SCRYPT_BLOCK_SIZE=8
PASSWORD_SCRYPT_PARALLELIZATION=1
PASSWORD_RESET_TTL_MINUTES=30
LOG_LEVEL=info

